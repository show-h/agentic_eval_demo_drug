{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tooluse_60TUwoKgQlPQAfLro9fapr","type":"tool_result","content":"\"\"\"\nCustomer Service Mock API Server\n用于 Agentic Eval Demo - 模拟真实客服退货退款系统\n\n启动方式: python app.py --scenario case_01 --port 5000\n\"\"\"\n\nimport json\nimport time\nimport os\nimport sys\nimport argparse\nfrom datetime import datetime\nfrom flask import Flask, request, jsonify\n\napp = Flask(__name__)\n\n# === Global State ===\ncall_log = []  # 记录所有API调用（即Agent轨迹）\nscenario_config = {}  # 当前case的失败配置\norders_db = {}  # 订单数据库\nconversations_db = {}  # 工单对话数据库（含 attachments / supplementary_messages）\ntransactions_db = {}  # 支付流水数据库\ncall_counts = {}  # 记录每个endpoint被调用的次数（用于控制第N次失败）\nrefund_state = {}  # 退款状态追踪 {order_id: \"processing\"|\"completed\"|None}\nrevealed_messages = {}  # 已经透露给 agent 的补充消息索引 {ticket_id: set(idx)}\n\n\ndef _strip_internal_fields(obj):\n    \"\"\"递归剥离所有以 '_' 开头的内部字段（开发注释 / 调试笔记），\n    防止它们被 API 响应暴露给 agent 而泄题。\n\n    保留 '$' 开头的字段（如 $schema），那是公开规范字段。\n    \"\"\"\n    if isinstance(obj, dict):\n        return {k: _strip_internal_fields(v) for k, v in obj.items()\n                if not (k.startswith('_') and not k.startswith('$'))}\n    elif isinstance(obj, list):\n        return [_strip_internal_fields(x) for x in obj]\n    return obj\n\n\ndef load_scenario(scenario_id):\n    \"\"\"加载scenario配置\"\"\"\n    global scenario_config, orders_db, conversations_db, transactions_db\n    global call_counts, refund_state, revealed_messages\n\n    scenario_path = os.path.join(os.path.dirname(__file__), 'scenarios', f'{scenario_id}.json')\n    with open(scenario_path, 'r', encoding='utf-8') as f:\n        scenario_config = json.load(f)\n\n    db_path = os.path.join(os.path.dirname(__file__), 'data', 'orders_db.json')\n    with open(db_path, 'r', encoding='utf-8') as f:\n        orders_db = json.load(f)\n\n    conv_path = os.path.join(os.path.dirname(__file__), 'data', 'conversations_db.json')\n    if os.path.exists(conv_path):\n        with open(conv_path, 'r', encoding='utf-8') as f:\n            conversations_db = json.load(f)\n    else:\n        conversations_db = {}\n\n    tx_path = os.path.join(os.path.dirname(__file__), 'data', 'transactions_db.json')\n    if os.path.exists(tx_path):\n        with open(tx_path, 'r', encoding='utf-8') as f:\n            transactions_db = json.load(f)\n    else:\n        transactions_db = {\"transactions\": {}}\n\n    # ⭐ Defensive：装载后立即剥离所有 _ 开头字段（防止开发笔记泄题给 agent）\n    orders_db = _strip_internal_fields(orders_db)\n    conversations_db = _strip_internal_fields(conversations_db)\n    transactions_db = _strip_internal_fields(transactions_db)\n\n    call_counts = {}\n    call_log.clear()\n    refund_state.clear()\n    revealed_messages = {}\n\n    # 清理上一轮 agent 的 finalize 提交（防污染）\n    finalized_path = os.path.join(os.path.dirname(__file__), 'last_finalized.json')\n    if os.path.exists(finalized_path):\n        os.remove(finalized_path)\n\n\ndef log_call(endpoint, method, req_data, resp_data, status_code, latency_ms):\n    \"\"\"记录API调用到日志\"\"\"\n    call_log.append({\n        \"timestamp\": datetime.now().isoformat(),\n        \"endpoint\": endpoint,\n        \"method\": method,\n        \"request\": req_data,\n        \"response\": resp_data,\n        \"status_code\": status_code,\n        \"latency_ms\": latency_ms\n    })\n    # 实时写入文件\n    log_path = os.path.join(os.path.dirname(__file__), 'call_log.json')\n    with open(log_path, 'w', encoding='utf-8') as f:\n        json.dump(call_log, f, ensure_ascii=False, indent=2)","is_error":false}]},"parent_tool_use_id":null,"session_id":"020de6b1-6997-463e-b146-893709f1f7fd","uuid":"7a603210-fd7f-4446-bd62-4b401fabb16a","timestamp":"2026-05-30T18:12:02.464Z","tool_use_result":{"stdout":"\"\"\"\nCustomer Service Mock API Server\n用于 Agentic Eval Demo - 模拟真实客服退货退款系统\n\n启动方式: python app.py --scenario case_01 --port 5000\n\"\"\"\n\nimport json\nimport time\nimport os\nimport sys\nimport argparse\nfrom date