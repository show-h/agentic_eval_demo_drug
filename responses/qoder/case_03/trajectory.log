\": {\n            \"type\": \"string\",\n            \"description\": \"服药说明，例如 '饭前半小时服用'、'体温>38.5℃时服用'\"\n          },\n          \"indication\": {\n            \"type\": \"string\",\n            \"description\": \"用药指征（针对哪个症状/诊断），可写主诊断 ICD-10 或自由文本\"\n          }\n        }\n      }\n    },\n    \"non_drug_advice\": {\n      \"type\": \"array\",\n      \"description\": \"非药物医嘱（生活方式/饮食/复诊）\",\n      \"items\": {\"type\": \"string\"}\n    },\n    \"clinical_reasoning\": {\n      \"type\": \"string\",\n      \"description\": \"用药决策的临床思路。必须显式覆盖：(1) 为什么开这些药；(2) 与病人特殊情况（年龄/过敏/肝肾功能/合并用药）的匹配性；(3) 预期监测/复诊节点。\"\n    },\n    \"explicit_avoidance\": {\n      \"type\": \"array\",\n      \"description\": \"显式说明本次刻意避免使用的药物/方案及原因。例如：[{drug_or_class: '抗生素', reason: '病毒性感染无指征'}]。这是验证 agent 是否理解临床决策边界的关键字段。\",\n      \"items\": {\n        \"type\": \"object\",\n        \"required\": [\"drug_or_class\", \"reason\"],\n        \"properties\": {\n          \"drug_or_class\": {\"type\": \"string\"},\n          \"reason\": {\"type\": \"string\"}\n        }\n      }\n    },\n    \"follow_up\": {\n      \"type\": \"object\",\n      \"description\": \"随访计划\",\n      \"properties\": {\n        \"next_visit_days\": {\"type\": \"number\"},\n        \"red_flags\": {\n          \"type\": \"array\",\n          \"description\": \"需要立即返诊的危险征兆\",\n          \"items\": {\"type\": \"string\"}\n        }\n      }\n    }\n  }\n}","stderr":"\nShell cwd was reset to C:\\Users\\<USER>\\AppData\\Local\\Temp\\his-cpoe-20260531-142859-PlcLMA","interrupted":false,"isImage":false,"noOutputExpected":false}}
